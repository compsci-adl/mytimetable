{
	"name": "mytimetable",
	"private": true,
	"version": "2.2.0",
	"type": "module",
	"scripts": {
		"prepare": "simple-git-hooks",
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "eslint ./src",
		"preview": "vite preview",
		"format": "prettier --write \"**/*.{js,ts,tsx,css,md,cjs,mjs,json,html}\"",
		"format:check": "prettier --check \"**/*.{js,ts,tsx,css,md,cjs,mjs,json,html}\"",
		"test": "vitest"
	},
	"dependencies": {
		"@atlaskit/pragmatic-drag-and-drop": "^1.8.1",
		"@fontsource-variable/outfit": "^5.2.8",
		"@heroui/react": "^2.8.10",
		"@tailwindcss/vite": "^4.2.4",
		"@tanstack/react-query": "^5.100.3",
		"@tanstack/react-query-devtools": "^5.100.3",
		"clsx": "^2.1.1",
		"dayjs": "^1.11.20",
		"framer-motion": "^12.38.0",
		"i18next": "^25.10.10",
		"i18next-browser-languagedetector": "^8.2.1",
		"ky": "^1.14.3",
		"mutative": "^1.3.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-error-boundary": "^6.1.1",
		"react-i18next": "^16.6.6",
		"react-icons": "^5.6.0",
		"simple-zustand-devtools": "^1.1.0",
		"sonner": "^2.0.7",
		"tailwindcss": "^4.2.4",
		"zustand": "^5.0.12",
		"zustand-mutative": "^1.3.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/umami": "^2.10.1",
		"@vitejs/plugin-react": "^5.2.0",
		"autoprefixer": "^10.5.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.4.26",
		"globals": "^17.5.0",
		"lint-staged": "^16.4.0",
		"msw": "^2.13.6",
		"prettier": "^3.8.3",
		"prettier-plugin-tailwindcss": "^0.7.3",
		"simple-git-hooks": "^2.13.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^7.3.2",
		"vite-plugin-pwa": "^1.2.0",
		"vitest": "^4.1.5",
		"workbox-build": "^7.4.0",
		"workbox-window": "^7.4.0"
	},
	"lint-staged": {
		"*.{js,ts,tsx,css,md,cjs,mjs,json,html}": [
			"prettier --write"
		]
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	},
	"pnpm": {
		"overrides": {
			"serialize-javascript@<=7.0.2": ">=7.0.3",
			"serialize-javascript@<7.0.5": ">=7.0.5"
		}
	}
}
